{
  "manifest_version": 3,
  "name": "Subscriptions to Watch Later Autoplaylist",
  "short_name": "YT AutoWL",
  "description": "Automatic playlist collector from YouTube subscriptions",
  "version": "0.2.0",
  "version_name": "0.2.0",
  "icons": {
    "128": "icon/icon.png"
  },
  "options_page": "src/settings/settings.html",
  "action": {
    "default_icon": "icon/icon.png",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["build/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "build/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon/icon.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "oauth2": {
    "client_id": "63911817448-jqopokpb65qot40t4h4mlde2nlbphmkc.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/youtube",
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "key": "",
  "permissions": ["storage", "identity", "notifications", "tabs", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
